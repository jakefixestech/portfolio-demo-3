---

<Layout
  title="Website Portfolio & Examples | Jake Fixes Tech — Littleton, NH"
  description="Browse example websites built by Jake Fixes Tech. Starter, Professional and Premium package examples showing real-world results for small businesses."
>

  <!-- Header Banner -->
  <section style="position:relative;overflow:hidden;background-color:rgb(30,64,175);">
    <img src="/hero.jpg" alt="Professional tech workspace with dual monitors" fetchpriority="high" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;" />
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(30,64,175,0.88),rgba(37,99,235,0.88));z-index:1;"></div>
    <div style="max-width:56rem;margin:0 auto;padding:4rem 1.5rem 5rem;text-align:center;position:relative;z-index:2;">
      <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#93c5fd;">Portfolio</p>
      <h1 style="margin-top:0.5rem;font-size:2.5rem;font-weight:800;color:white;line-height:1.2;">Example Websites</h1>
      <p style="margin-top:1rem;color:#bfdbfe;font-size:1.1rem;line-height:1.75;max-width:42rem;margin-left:auto;margin-right:auto;">
        Every example site is mobile responsive, WCAG AA accessible, scores 10/10 on WAVE and 100/100 on Lighthouse. This is the standard I hold all my work to.
      </p>
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:0.75rem;margin-top:1.5rem;">
        <span class="score-badge">✅ 10/10 WAVE</span>
        <span class="score-badge">✅ 100/100 Lighthouse</span>
        <span class="score-badge">✅ WCAG AA</span>
        <span class="score-badge">✅ Mobile Responsive</span>
      </div>
    </div>
  </section>

  <!-- Filter Tabs -->
  <div class="filter-bar" role="tablist" aria-label="Filter portfolio by tier">
    <button class="filter-tab active" data-filter="all" role="tab" aria-selected="true">All</button>
    <button class="filter-tab" data-filter="starter" role="tab" aria-selected="false">Starter <span class="tab-price">$750</span></button>
    <button class="filter-tab" data-filter="pro" role="tab" aria-selected="false">Professional <span class="tab-price">$2,000</span></button>
    <button class="filter-tab" data-filter="premium" role="tab" aria-selected="false">Premium <span class="tab-price">$3,500+</span></button>
    <button class="filter-tab" data-filter="demo" role="tab" aria-selected="false">Demos</button>
  </div>

  <!-- Results count -->
  <div style="max-width:80rem;margin:0 auto;padding:1.25rem 1.5rem 0;">
    <p id="results-count" style="color:#6b7280;font-size:0.875rem;"></p>
  </div>

  <!-- Portfolio Sections -->
  <div id="portfolio-list" style="background:#f8fafc;padding:2rem 0 4rem;">

    {sites.map((site, index) => (
      <article
        class="portfolio-item"
        data-tier={site.tier}
        style="max-width:80rem;margin:0 auto 3rem;padding:0 1.5rem;"
      >
        <a
          href={site.url}
          target="_blank"
          rel="noopener noreferrer"
          class={`portfolio-row ${index % 2 === 1 ? 'reverse' : ''}`}
          aria-label={`View ${site.name} example website`}
        >
          <!-- Image -->
          <div class="portfolio-img-wrap">
            <img
              src={site.image}
              alt={`Screenshot of ${site.name} website`}
              class="portfolio-img"
              loading={index === 0 ? 'eager' : 'lazy'}
              decoding="async"
            />
          </div>

          <!-- Text -->
          <div class="portfolio-text">
            <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
              <span class="tier-pill" style={`background:${site.tierBg};color:${site.tierColor};`}>{site.tierLabel}</span>
              {site.pages > 0 && (
                <span style="font-size:0.8rem;color:#6b7280;">{site.pages} page{site.pages !== 1 ? 's' : ''}</span>
              )}
            </div>
            <h2 style="font-size:clamp(1.5rem,3vw,2rem);font-weight:800;color:#111827;line-height:1.2;margin-bottom:0.5rem;">
              {site.name}
            </h2>
            <p style="font-size:0.875rem;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:1rem;">
              {site.industry} · {site.location}
            </p>
            <p style="font-size:1rem;color:#374151;line-height:1.7;margin-bottom:1.5rem;">
              {site.description}
            </p>
            <span class="view-link">
              View Example
              <svg style="width:1rem;height:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </span>
          </div>
        </a>
      </article>
    ))}

    <!-- Coming Soon Premium -->
    <div class="portfolio-item" data-tier="premium" style="max-width:80rem;margin:0 auto 3rem;padding:0 1.5rem;">
      <div class="coming-soon-row">
        <div class="coming-soon-icon">🚧</div>
        <div>
          <span class="tier-pill" style="background:#ede9fe;color:#7c3aed;margin-bottom:0.75rem;display:inline-block;">Premium</span>
          <h2 style="font-size:1.5rem;font-weight:800;color:#374151;margin-bottom:0.5rem;">Coming Soon</h2>
          <p style="color:#6b7280;">80+ page custom build · Est. $6,000</p>
        </div>
      </div>
    </div>

    <div class="portfolio-item" data-tier="premium" style="max-width:80rem;margin:0 auto 3rem;padding:0 1.5rem;">
      <div class="coming-soon-row">
        <div class="coming-soon-icon">🚧</div>
        <div>
          <span class="tier-pill" style="background:#ede9fe;color:#7c3aed;margin-bottom:0.75rem;display:inline-block;">Premium</span>
          <h2 style="font-size:1.5rem;font-weight:800;color:#374151;margin-bottom:0.5rem;">Coming Soon</h2>
          <p style="color:#6b7280;">150+ page custom build · Est. $10,000</p>
        </div>
      </div>
    </div>

    <!-- Empty state -->
    <div id="empty-state" style="display:none;text-align:center;padding:4rem 1.5rem;">
      <p style="color:#6b7280;font-size:1rem;">No examples in this category yet — check back soon!</p>
    </div>

    <!-- Back to Web Design -->
    <div style="text-align:center;padding-top:2rem;border-top:1px solid #e5e7eb;margin:2rem 1.5rem 0;">
      <a href="/web-services" style="display:inline-flex;align-items:center;gap:0.5rem;color:#2563eb;font-weight:600;font-size:0.95rem;text-decoration:none;">
        <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Back to Web Design & Pricing
      </a>
    </div>

  </div>

</Layout>

<style>
  .score-badge {
    background: rgba(255,255,255,0.15);
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    border: 1px solid rgba(255,255,255,0.25);
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    background: white;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid #e5e7eb;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .filter-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1.125rem;
    border-radius: 9999px;
    border: 2px solid #e5e7eb;
    background: white;
    color: #374151;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }

  .filter-tab:hover { border-color: #2563eb; color: #2563eb; }
  .filter-tab.active { background: #2563eb; border-color: #2563eb; color: white; }
  .tab-price { font-size: 0.75rem; font-weight: 500; color: inherit; }

  .portfolio-row {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    background: white;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .portfolio-row:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.13);
    transform: translateY(-2px);
  }

  .portfolio-img-wrap {
    width: 100%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .portfolio-img {
    width: 100%;
    height: 240px;
    object-fit: cover;
    object-position: top;
    display: block;
    transition: transform 0.4s ease;
  }

  .portfolio-row:hover .portfolio-img {
    transform: scale(1.02);
  }

  .portfolio-text {
    padding: 2rem;
  }

  .tier-pill {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
  }

  .view-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #2563eb;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .coming-soon-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    border: 2px dashed #e5e7eb;
  }

  .coming-soon-icon {
    font-size: 2.5rem;
    flex-shrink: 0;
  }

  .portfolio-item[hidden] { display: none; }

  @media (min-width: 768px) {
    .portfolio-row {
      flex-direction: row;
      min-height: 22rem;
    }

    .portfolio-row.reverse {
      flex-direction: row-reverse;
    }

    .portfolio-img-wrap {
      width: 50%;
    }

    .portfolio-img {
      height: 100%;
    }

    .portfolio-text {
      width: 50%;
      padding: 3rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
  }

  @media (min-width: 1024px) {
    .portfolio-img-wrap { width: 55%; }
    .portfolio-text { width: 45%; }
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
  const items = document.querySelectorAll<HTMLElement>('.portfolio-item');
  const countEl = document.getElementById('results-count');
  const emptyState = document.getElementById('empty-state');

  function updateCount(filter: string) {
    const visible = filter === 'all'
      ? items.length
      : [...items].filter(c => c.dataset.tier === filter).length;
    if (countEl) {
      countEl.textContent = `Showing ${visible} example${visible !== 1 ? 's' : ''}${filter !== 'all' ? ` in ${filter === 'demo' ? 'Demos' : filter.charAt(0).toUpperCase() + filter.slice(1)}` : ''}`;
    }
    if (emptyState) {
      emptyState.style.display = visible === 0 ? 'block' : 'none';
    }
  }

  function filterItems(filter: string) {
    items.forEach(item => {
      item.hidden = filter !== 'all' && item.dataset.tier !== filter;
    });
    updateCount(filter);
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      filterItems(tab.dataset.filter ?? 'all');
    });
  });

  updateCount('all');
</script>