    tierBg: '#dbeafe',
    name: 'Granite State Plumbing & Drain',
    industry: 'Plumbing & Drain Services',
    location: 'Littleton, NH',
    pages: 3,
    url: 'https://starter1.jakefixestech.com',
    image: '/starter1.webp',
    description: 'A clean, professional 3-page website for a local plumbing and drain service company — built to convert visitors into calls.',
  },
  {
    tier: 'starter',
    tierLabel: 'Starter',
    tierColor: '#1e40af',
    tierBg: '#dbeafe',
    name: 'White Mountain Maple Co.',
    industry: 'Small Batch NH Maple Syrup',
    location: 'Littleton, NH',
    pages: 3,
    url: 'https://starter2.jakefixestech.com',
    image: '/starter2.webp',
    description: 'A warm, story-driven 3-page site for a small batch maple syrup producer nestled in the White Mountains of New Hampshire.',
  },
  {
